# Citadel Cluster Configuration
# Copy to .env and customize

# API port for load balancer (default: 8085)
CITADEL_API_PORT=8085

# HAProxy stats port (default: 8404)
HAPROXY_STATS_PORT=8404

# Rust log level (default: info)
RUST_LOG=citadel_lens=info,citadel_protocols=debug

# Admin public key (hex-encoded ed25519, optional)
# ADMIN_PUBLIC_KEY=a26dd671c67dce9ca905b65f3dcb4bd0ca4803a357916abdb7cdd12e8284ffb3
